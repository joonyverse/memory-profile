# ============================================================
# 서버 프로필 환경 설정 파일 템플릿
# 이 파일을 복사하여 .env.서버이름 으로 저장한 후,
# 실제 서버 IP 및 설정을 기입하세요.
#
# 사용법:
#   cp .env.example .env.my-server
#   vi .env.my-server
#   cd example_project/build
#   cmake .. -DENV_FILE=../../.env.my-server
#   make trace-dynamic-remote
# ============================================================

# 원격 서버 접속 정보
TARGET_IP=192.168.x.x
TARGET_PORT=9999

# GDB 바이너리 (이기종 디버깅 시 gdb-multiarch 사용)
#   x86_64 → x86_64: gdb
#   x86_64 → ARM64:  gdb-multiarch
GDB_BIN=gdb

# 원격 서버에서의 바이너리 경로
REMOTE_BINARY_PATH=/opt/vran/bin/vran_main

# 셀 셋업 완료 함수명 (브레이크포인트 대상)
CELL_SETUP_FUNC=complete_cell_setup
